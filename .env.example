# =============================================================================
# Copy to ".env" and fill in values (never commit real secrets).
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — app will not start without these
# -----------------------------------------------------------------------------

# ElevenLabs tool header: x-elevenlabs-secret-dentalpro
X_ELEVENLABS_SECRET_DENTALPRO=

# Legacy (optional — still read if DENTALPRO unset)
# X_ELEVENLABS_SECRET_PLUMBINGPRO=
# X_ELEVENLABS_SECRET=

# Google Sheet used for company data, SMS templates, call logs, appointments, etc.
GOOGLE_SHEET_ID=

# Service account that can read/write the sheet (and Calendar if configured)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# PEM private key — one line; use \n for newlines in Vercel/hosting
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional — ConvAI embed on the docs homepage (defaults to repo agent if unset)
# NEXT_PUBLIC_ELEVENLABS_AGENT_ID=agent_...

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Next.js / Express listen port (default 3000)
PORT=3000

# -----------------------------------------------------------------------------
# OPTIONAL — Google Sheets behaviour
# -----------------------------------------------------------------------------

# Cache sheet reads for N seconds (>0 enables cache)
SHEET_DATA_CACHE_TTL_SECONDS=0

# -----------------------------------------------------------------------------
# OPTIONAL — Google Calendar (POST /api/book_appointment)
# Enable Calendar API in GCP; share calendar with service account (Editor).
# -----------------------------------------------------------------------------

GOOGLE_CALENDAR_ID=

# IANA timezone for timed slots (default Europe/London if unset in code path)
GOOGLE_CALENDAR_TIMEZONE=Europe/London

# -----------------------------------------------------------------------------
# OPTIONAL — Twilio (POST /api/send-sms)
# -----------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# OPTIONAL — Escalation webhook (POST /api/escalate-human)
# -----------------------------------------------------------------------------

ESCALATION_WEBHOOK_URL=
ESCALATION_WEBHOOK_SECRET=
ESCALATION_TRANSFER_NUMBER=

# -----------------------------------------------------------------------------
# OPTIONAL — HubSpot (POST /api/crm-sync)
# -----------------------------------------------------------------------------

HUBSPOT_ACCESS_TOKEN=
HUBSPOT_DEFAULT_TICKET_PIPELINE=
HUBSPOT_DEFAULT_TICKET_STAGE_OPEN=
HUBSPOT_DEFAULT_TICKET_STAGE_CLOSED=

# If truthy (1/true/yes) and status is callback_pending, creates a HubSpot task
HUBSPOT_CREATE_TASKS=
HUBSPOT_CALLBACK_TASK_OWNER_ID=

# Association type IDs (defaults work for many portals; override if needed)
HUBSPOT_ASSOC_TICKET_CONTACT_TYPE_ID=16
HUBSPOT_ASSOC_NOTE_CONTACT_TYPE_ID=190
HUBSPOT_ASSOC_NOTE_TICKET_TYPE_ID=228
HUBSPOT_ASSOC_TASK_CONTACT_TYPE_ID=204
HUBSPOT_ASSOC_TASK_TICKET_TYPE_ID=216

# -----------------------------------------------------------------------------
# OPTIONAL — Debugging
# -----------------------------------------------------------------------------

# Set to 1 to include auth diagnostics on failed tool requests (remove in prod)
DEBUG_PLUMBING_AUTH=

# -----------------------------------------------------------------------------
# OPTIONAL — Smoke test script (npm run smoke)
# -----------------------------------------------------------------------------

SMOKE_BASE_URL=http://127.0.0.1:3000
# Omit for single-clinic smoke (uses first Company row); set to target a specific sheet row
SMOKE_COMPANY_ID=
SMOKE_SKIP_SEND_SMS=
SMOKE_SKIP_LOG_CALL=
SMOKE_SMS_TO=
SMOKE_SMS_TEMPLATE_ID=SMS01
